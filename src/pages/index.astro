---
import BaseHead from '../components/BaseHead.astro';

const SITE_TITLE = "Luke & Catherine";
const SITE_DESCRIPTION = "Wedding Invitation";
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

	<style>
		:root {
			--bg: #f8f4ef;
			--text: #4b3b36;
			--accent: #d8b4a0;
			--envelope: #f1e4d7;
			--shadow: rgba(0,0,0,0.15);
		}

		body {
			margin: 0;
			font-family: "Georgia", serif;
			background: linear-gradient(to bottom, #faf7f2, #f3ebe2);
			color: var(--text);
			display: flex;
			justify-content: center;
			align-items: center;
			height: 100vh;
			overflow: hidden;
		}

		main {
			text-align: center;
			padding: 2rem;
		}

		h1 {
			font-size: 3rem;
			font-weight: 400;
			margin-bottom: 0.5rem;
			letter-spacing: 2px;
		}

		p {
			font-size: 1.2rem;
			margin-bottom: 3rem;
			opacity: 0.85;
		}

		.envelope-link {
			text-decoration: none;
		}

		.envelope-wrapper {
			position: relative;
			width: 320px;
			height: 220px;
			margin: auto;
			cursor: pointer;
			transition: transform 0.3s ease;
		}

		.envelope-wrapper:hover {
			transform: translateY(-8px) scale(1.02);
		}

		.envelope {
			position: absolute;
			width: 100%;
			height: 100%;
			background: var(--envelope);
			border-radius: 8px;
			box-shadow: 0 12px 30px var(--shadow);
			overflow: hidden;
		}

		.flap {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: #ead7c5;
			clip-path: polygon(0 0, 50% 55%, 100% 0);
			transition: transform 0.6s ease;
			transform-origin: top;
		}

		.envelope-wrapper:hover .flap {
			transform: rotateX(180deg);
		}

		.letter {
			position: absolute;
			bottom: 20px;
			left: 50%;
			transform: translateX(-50%);
			width: 85%;
			height: 140px;
			background: white;
			border-radius: 4px;
			box-shadow: 0 4px 10px rgba(0,0,0,0.08);
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1rem;
			color: #777;
			transition: transform 0.4s ease;
		}

		.envelope-wrapper:hover .letter {
			transform: translateX(-50%) translateY(-18px);
		}

		.seal {
			position: absolute;
			top: 72px;
			left: 50%;
			transform: translateX(-50%);
			width: 52px;
			height: 52px;
			background: #b76e79;
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			color: white;
			font-size: 1.1rem;
			font-weight: bold;
			box-shadow: 0 4px 10px rgba(0,0,0,0.15);
			z-index: 5;
		}

		.footer-text {
			margin-top: 2rem;
			font-size: 0.95rem;
			opacity: 0.7;
		}

		@media (max-width: 600px) {
			h1 {
				font-size: 2.2rem;
			}

			.envelope-wrapper {
				width: 260px;
				height: 180px;
			}
		}
	</style>
</head>

<body>
	<main>
		<h1>Luke & Catherine</h1>

		<p>Click below to open your invitation</p>

		<a class="envelope-link" href="/invitation.pdf" target="_blank">
			<div class="envelope-wrapper">

				<div class="envelope">
					<div class="flap"></div>

					<div class="letter">
						Open Invitation
					</div>

					<div class="seal">
						L&C
					</div>
				</div>

			</div>
		</a>

		<div class="footer-text">
			We cannot wait to celebrate with you
		</div>
	</main>
</body>
</html>
