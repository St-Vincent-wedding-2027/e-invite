---
const SITE_TITLE = "Catherine & Luke";
const SITE_DESCRIPTION = "Wedding Invitation";
---

<!doctype html>
<html lang="en">
<head>
	<title>{SITE_TITLE}</title>

	<meta charset="UTF-8" />
	<meta name="description" content={SITE_DESCRIPTION} />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />

	<style>
		:root {
			--bg1: #faf7f2;
			--bg2: #f2e8de;

			--paper: #fffdfb;

			--envelope: #e7d6c6;
			--envelope-dark: #dcc5b2;

			--seal: #a44c58;

			--text: #4e4039;

			--shadow: rgba(0,0,0,0.15);
		}

		* {
			box-sizing: border-box;
		}

		body {
			margin: 0;
			min-height: 100vh;

			display: flex;
			align-items: center;
			justify-content: center;

			font-family: Georgia, serif;

			background:
				radial-gradient(circle at top, rgba(255,255,255,0.5), transparent 40%),
				linear-gradient(to bottom, var(--bg1), var(--bg2));

			color: var(--text);

			overflow: hidden;
		}

		main {
			text-align: center;
			padding: 2rem;
		}

		h1 {
			font-size: clamp(2.2rem, 5vw, 3.5rem);
			font-weight: 400;
			letter-spacing: 2px;
			margin-bottom: 1rem;
		}

		.subtitle {
			font-size: 1.1rem;
			opacity: 0.75;
			margin-bottom: 3rem;
		}

		/* ENVELOPE */

		.envelope-wrapper {
			position: relative;
			width: 340px;
			height: 240px;

			margin: auto;

			cursor: pointer;

			perspective: 1400px;
		}

		.envelope {
			position: relative;
			width: 100%;
			height: 100%;
		}

		/* BACK */

		.envelope-back {
			position: absolute;
			inset: 0;

			background: var(--envelope);

			border-radius: 12px;

			box-shadow:
				0 15px 35px var(--shadow),
				inset 0 1px 0 rgba(255,255,255,0.4);

			z-index: 1;

			overflow: hidden;
		}

		/* SIDE SHAPES */

		.envelope-back::before,
		.envelope-back::after {
			content: "";

			position: absolute;
			bottom: 0;

			width: 50%;
			height: 100%;

			background: rgba(255,255,255,0.15);
		}

		.envelope-back::before {
			left: 0;

			clip-path: polygon(0 100%, 100% 0, 100% 100%);
		}

		.envelope-back::after {
			right: 0;

			clip-path: polygon(0 0, 100% 100%, 0 100%);
		}

		/* LETTER */

		.letter {
			position: absolute;

			left: 50%;
			bottom: 10px;

			width: 88%;
			height: 190px;

			transform:
				translateX(-50%)
				translateY(125px);

			background: var(--paper);

			border-radius: 8px;

			box-shadow:
				0 5px 15px rgba(0,0,0,0.08);

			z-index: 3;

			transition:
				transform 1.3s cubic-bezier(.22,1,.36,1);

			display: flex;
			align-items: center;
			justify-content: center;

			padding: 1.5rem;
		}

		.letter-content {
			text-align: center;
			opacity: 0.75;
		}

		.letter-content h2 {
			margin: 0 0 0.5rem;
			font-weight: 400;
		}

		/* FRONT FOLD */

		.envelope-front {
			position: absolute;

			bottom: 0;
			left: 0;

			width: 100%;
			height: 68%;

			background: var(--envelope);

			clip-path: polygon(0 100%, 50% 0, 100% 100%);

			z-index: 4;
		}

		/* FLAP */

		.flap {
			position: absolute;

			top: 0;
			left: 0;

			width: 100%;
			height: 52%;

			background: var(--envelope-dark);

			clip-path: polygon(0 0, 50% 100%, 100% 0);

			transform-origin: top center;

			transition:
				transform 1s cubic-bezier(.77,0,.18,1);

			z-index: 6;

			backface-visibility: hidden;
		}

		/* SEAL */

		.seal {
			position: absolute;

			top: 78px;
			left: 50%;

			transform: translateX(-50%);

			width: 58px;
			height: 58px;

			border-radius: 50%;

			background: var(--seal);

			display: flex;
			align-items: center;
			justify-content: center;

			color: white;

			font-size: 1rem;
			font-weight: bold;

			box-shadow:
				0 6px 15px rgba(0,0,0,0.2);

			z-index: 10;

			transition:
				transform 0.5s ease,
				opacity 0.5s ease;
		}

		/* OPEN STATE */

		.envelope-wrapper.open .seal {
			transform:
				translateX(-50%)
				scale(1.5)
				rotate(25deg);

			opacity: 0;
		}

		.envelope-wrapper.open .flap {
			transform: rotateX(180deg);
		}

		.envelope-wrapper.open .letter {
			transform:
				translateX(-50%)
				translateY(-70px);
		}

		.footer {
			margin-top: 2.5rem;

			font-size: 0.95rem;

			opacity: 0.65;
		}

		/* MOBILE */

		@media (max-width: 480px) {

			.envelope-wrapper {
				width: 300px;
				height: 215px;
			}

			.letter {
				height: 170px;
			}
		}
	</style>
</head>

<body>

	<main>

		<h1>Catherine & Luke</h1>

		<div class="subtitle">
			Click the seal to open
		</div>

		<div class="envelope-wrapper" id="envelope">

			<div class="envelope">

				<div class="envelope-back"></div>

				<div class="letter">

					<div class="letter-content">
						<h2>You’re Invited</h2>
						<p>
							Tap to open your invitation
						</p>
					</div>

				</div>

				<div class="envelope-front"></div>

				<div class="flap"></div>

				<div class="seal" id="seal">
					C&L
				</div>

			</div>

		</div>

		<div class="footer">
			We cannot wait to celebrate with you
		</div>

	</main>

	<script>
		if (localStorage.getItem('wedding_access') !== 'true') {
			window.location.href = '/';
		}

		const seal = document.getElementById('seal');
		const envelope = document.getElementById('envelope');

		let opened = false;

		seal.addEventListener('click', () => {

			if (opened) return;

			opened = true;

			envelope.classList.add('open');

			setTimeout(() => {
				window.location.href = '/invitation.pdf';
			}, 2200);

		});
	</script>

</body>
</html>