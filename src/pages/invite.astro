---
const SITE_TITLE = "Catherine & Luke";
const SITE_DESCRIPTION = "Wedding Invitation";
---

<!doctype html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<title>{SITE_TITLE}</title>

	<meta name="description" content={SITE_DESCRIPTION} />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />

	<style>

		:root {
			--bg1: #faf7f2;
			--bg2: #f2e8de;
			--envelope: #e7d6c6;
			--envelope-dark: #dcc5b2;
			--seal: #a44c58;
			--shadow: rgba(0,0,0,0.15);
		}

		* { box-sizing: border-box; }

		body {
			margin: 0;
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			font-family: Georgia, serif;
			background: linear-gradient(to bottom, var(--bg1), var(--bg2));
			overflow: hidden;
			color: #4e4039;
		}

		main {
			text-align: center;
			padding: 2rem;
		}

		h1 {
			font-size: clamp(2.4rem, 5vw, 3.6rem);
			font-weight: 400;
			letter-spacing: 2px;
			margin-bottom: 1rem;
		}

		.subtitle {
			font-size: 1.1rem;
			opacity: 0.75;
			margin-bottom: 3rem;
			transition: opacity 0.3s ease;
		}

		/* ENVELOPE */
		.envelope-wrapper {
			position: relative;
			width: 340px;
			height: 260px;
			margin: auto;
			cursor: pointer;
			perspective: 1400px;
		}

		.envelope {
			position: relative;
			width: 100%;
			height: 100%;
			overflow: hidden;
			border-radius: 12px;
		}

		.envelope-back {
			position: absolute;
			inset: 0;
			background: var(--envelope);
			border-radius: 12px;
			box-shadow: 0 15px 35px var(--shadow),
			            inset 0 1px 0 rgba(255,255,255,0.4);
			z-index: 1;
		}

		.envelope-back::before,
		.envelope-back::after {
			content: "";
			position: absolute;
			bottom: 0;
			width: 50%;
			height: 100%;
			background: rgba(255,255,255,0.12);
		}

		.envelope-back::before {
			left: 0;
			clip-path: polygon(0 100%, 100% 0, 100% 100%);
		}

		.envelope-back::after {
			right: 0;
			clip-path: polygon(0 0, 100% 100%, 0 100%);
		}

.envelope-pocket {
	position: absolute;
	left: 0;
	bottom: 0;

	width: 100%;
	height: 55%; /* bottom half of envelope */

	background: var(--envelope);

	z-index: 2; /* ABOVE PNG, BELOW front fold */

	clip-path: polygon(
		0 100%,
		50% 0,
		100% 100%
	);

	box-shadow: inset 0 10px 20px rgba(0,0,0,0.08);
}

		/* INVITE PNG */
		.letter {
	position: absolute;

	left: 50%;
	bottom: -235px;

	transform: translateX(-50%);

	width: 92%;
	height: 360px;

	z-index: 3;

	transition:
		bottom 1.2s cubic-bezier(.22,1,.36,1),
		transform 1.2s ease;

	border-radius: 10px;

	box-shadow:
		0 10px 30px rgba(0,0,0,0.18);

	overflow: hidden;
}

		.invite-image {
	width: 100%;
	height: 100%;

	object-fit: cover;

	object-position: center top;

	display: block;
}

		/* FRONT */
		.envelope-front {
			position: absolute;
			bottom: 0;
			left: 0;
			width: 100%;
			height: 68%;
			background: var(--envelope);
			clip-path: polygon(0 100%, 50% 0, 100% 100%);
			z-index: 5;
		}

		/* FLAP */
		.flap {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 52%;
			background: var(--envelope-dark);
			clip-path: polygon(0 0, 50% 100%, 100% 0);
			transform-origin: top;
			transition: transform 1s cubic-bezier(.77,0,.18,1);
			z-index: 6;
		}

		/* SEAL */
		.seal {
			position: absolute;
			top: 78px;
			left: 50%;
			transform: translateX(-50%);
			width: 58px;
			height: 58px;
			border-radius: 50%;
			background: var(--seal);
			display: flex;
			align-items: center;
			justify-content: center;
			color: white;
			font-weight: bold;
			box-shadow: 0 6px 15px rgba(0,0,0,0.2);
			z-index: 7;
			transition: transform 0.5s ease, opacity 0.5s ease;
		}

		.envelope-wrapper.open .seal {
			transform: translateX(-50%) scale(1.5) rotate(25deg);
			opacity: 0;
		}

		.envelope-wrapper.open .flap {
			transform: rotateX(180deg) translateY(-10px);
		}

		/* 👇 key fix: more visible space when open */
		.envelope-wrapper.open .letter {
	bottom: -40px;
	transform: translateX(-50%) scale(1.03);
}

		.footer {
			margin-top: 2.5rem;
			font-size: 0.95rem;
			opacity: 0.65;
		}

	</style>
</head>

<body>

	<main>

		<h1>Catherine & Luke</h1>

		<div class="subtitle" id="subtitle">
			Click the seal to open
		</div>

		<div class="envelope-wrapper" id="envelope">

			<div class="envelope">

				<div class="envelope-back"></div>
				<div class="envelope-pocket"></div>
				<div class="letter">
					<img src="/Wedding Invite - 1.png" class="invite-image" />
				</div>

				<div class="envelope-front"></div>
				<div class="flap"></div>

				<div class="seal" id="seal">C&L</div>

			</div>
		</div>

		<div class="footer">
	We cannot wait to celebrate with you<br />
	<span style="font-size:0.8rem; opacity:0.7;">
		Made by Luke ©
	</span>
</div>

	</main>

	<script>

		if (localStorage.getItem('wedding_access') !== 'true') {
			window.location.href = '/';
		}

		const seal = document.getElementById('seal');
		const envelope = document.getElementById('envelope');
		const subtitle = document.getElementById('subtitle');

		let opened = false;

		seal.addEventListener('click', () => {
			if (opened) return;

			opened = true;
			envelope.classList.add('open');

			// 👇 UX upgrade: change instruction text
			setTimeout(() => {
				subtitle.textContent = "Click invite";
			}, 900);
		});

	</script>

</body>
</html>
