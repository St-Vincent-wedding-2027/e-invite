---
const SITE_TITLE = "Catherine & Luke";
const SITE_DESCRIPTION = "Wedding Invitation";
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<title>{SITE_TITLE}</title>

	<meta name="description" content="{SITE_DESCRIPTION}" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />

	<style>
		:root {
			--bg1: #faf7f2;
			--bg2: #f2e8de;

			--envelope: #e8d5c4;
			--envelope-dark: #d7bea7;

			--seal: #b08d6d;

			--text: #3d352f;
			--shadow: rgba(0, 0, 0, 0.15);
		}

		* {
			box-sizing: border-box;
		}

		body {
			margin: 0;
			font-family: Georgia, serif;
			background:
				radial-gradient(circle at top, var(--bg1), var(--bg2));
			color: var(--text);
			min-height: 100vh;

			display: flex;
			align-items: center;
			justify-content: center;

			padding: 2rem;
			text-align: center;
		}

		main {
			max-width: 500px;
			width: 100%;
		}

		h1 {
			font-size: clamp(2.5rem, 5vw, 4rem);
			margin-bottom: 0.5rem;
			letter-spacing: 2px;
		}

		.subtitle {
			font-size: 1.1rem;
			opacity: 0.75;
			margin-bottom: 2.5rem;
			transition: opacity 0.4s ease;
		}

		/* Envelope */

		.envelope-wrapper {
			position: relative;
			width: 360px;
			height: 280px;
			margin: 0 auto;
			perspective: 1200px;
		}

		.envelope {
			position: relative;
			width: 100%;
			height: 100%;
			overflow: visible;
		}

		.envelope-back {
			position: absolute;
			inset: 0;
			background: var(--envelope);
			border-radius: 14px;
			box-shadow: 0 15px 35px var(--shadow);
			z-index: 1;
			transition: opacity 1s ease;
		}

		.envelope-front {
			position: absolute;
			inset: auto 0 0;
			height: 58%;
			background: var(--envelope);
			clip-path: polygon(0 100%, 50% 0, 100% 100%);
			z-index: 4;
			transition: opacity 1s ease;
		}

		.flap {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 52%;
			background: var(--envelope-dark);
			clip-path: polygon(0 0, 50% 100%, 100% 0);

			transform-origin: top;
			z-index: 6;

			transition:
				transform 1s cubic-bezier(.77, 0, .18, 1),
				opacity 1s ease;
		}

		/* Letter */

		.letter {
			position: absolute;
			left: 50%;
			bottom: -240px;

			transform: translateX(-50%) scale(0.96);

			width: 94%;
			height: 430px;

			opacity: 0;
			pointer-events: none;

			transition:
				transform 1.1s cubic-bezier(.23, 1, .32, 1),
				opacity 0.8s ease;

			z-index: 2;
		}

		.letter img {
			width: 100%;
			height: 100%;
			object-fit: contain;
			display: block;
			background: white;
		}

		/* Seal */

		.seal {
			position: absolute;
			top: 78px;
			left: 50%;

			transform: translateX(-50%);

			width: 60px;
			height: 60px;
			border-radius: 50%;

			background: var(--seal);
			color: white;

			display: flex;
			align-items: center;
			justify-content: center;

			font-weight: bold;
			cursor: pointer;

			z-index: 10;

			transition:
				transform 0.5s ease,
				opacity 0.5s ease;
		}

		/* Hint */

		.click-hint {
			margin-top: 0.6rem;
			font-size: 0.85rem;

			opacity: 0;
			transform: translateY(6px);

			transition: all 0.6s ease;
			pointer-events: none;
		}

		.click-hint.show {
			opacity: 0.7;
			transform: translateY(0);
		}

		/* Footer */

		.footer {
			margin-top: 2.5rem;
			font-size: 0.95rem;
			line-height: 1.7;
			opacity: 0.65;
		}

		/* Open state */

		.envelope-wrapper.open .seal {
			opacity: 0;
			transform:
				translateX(-50%)
				scale(1.5)
				rotate(25deg);
		}

		.envelope-wrapper.open .flap {
			transform: rotateX(180deg) translateY(-30px);
			opacity: 0;
		}

		.envelope-wrapper.open .letter {
			opacity: 1;
			transform: translateX(-50%) scale(1);
			pointer-events: auto;
			z-index: 20;
		}

		/* Mobile */

		@media (max-width: 480px) {
			.envelope-wrapper {
				width: 310px;
				height: 240px;
			}

			.letter {
				height: 380px;
			}
		}
	</style>
</head>

<body>

	<main>

		<h1>Catherine & Luke</h1>

		<div class="subtitle" id="subtitle">
			You are invited
		</div>

		<div class="envelope-wrapper" id="envelope">

			<div class="envelope">

				<div class="envelope-back"></div>

				<div class="letter" id="letter">
					<img src="/invite-preview.png" alt="Wedding invitation preview" />
				</div>

				<div class="flap"></div>

				<div class="envelope-front"></div>

				<div class="seal" id="seal">
					L&C
				</div>

			</div>

		</div>

		<div class="footer">

			Made by Luke ©

			<div class="click-hint" id="clickHint">
				Click image to open your invitation
			</div>

		</div>

	</main>

	<script>
		if (localStorage.getItem('wedding_access') !== 'true') {
			window.location.href = '/';
		}

		const seal = document.getElementById('seal');
		const envelope = document.getElementById('envelope');
		const letter = document.getElementById('letter');
		const subtitle = document.getElementById('subtitle');
		const clickHint = document.getElementById('clickHint');

		let opened = false;

		seal.addEventListener('click', () => {

			if (opened) return;

			opened = true;

			envelope.classList.add('open');

			setTimeout(() => {
				subtitle.textContent = 'Click the invite';
				clickHint.classList.add('show');
			}, 800);

		});

		letter.addEventListener('click', () => {

			if (!opened) return;

			window.open('/invitation.pdf#view=FitH', '_blank');

		});
	</script>

</body>
</html>
