---
const SITE_TITLE = "Catherine & Luke";
const SITE_DESCRIPTION = "Wedding Invitation";
---

<!doctype html>
<html lang="en">
<head>

	<meta charset="UTF-8" />

	<title>{SITE_TITLE}</title>

	<meta
		name="description"
		content={SITE_DESCRIPTION}
	/>

	<meta
		name="viewport"
		content="width=device-width, initial-scale=1.0"
	/>

	<style>

		:root {

			--bg1: #faf7f2;
			--bg2: #f2e8de;

			--envelope: #e7d6c6;
			--envelope-dark: #dcc5b2;

			--seal: #a44c58;

			--text: #4e4039;

			--shadow: rgba(0,0,0,0.15);

		}

		* {
			box-sizing: border-box;
		}

		body {

			margin: 0;
			min-height: 100vh;

			display: flex;
			align-items: center;
			justify-content: center;

			font-family: Georgia, serif;

			background:
				linear-gradient(
					to bottom,
					var(--bg1),
					var(--bg2)
				);

			color: var(--text);

			overflow: hidden;

		}

		main {

			text-align: center;
			padding: 2rem;

		}

		h1 {

			font-size: clamp(2.4rem, 5vw, 3.6rem);

			font-weight: 400;

			letter-spacing: 2px;

			margin-bottom: 1rem;

		}

		.subtitle {

			font-size: 1.1rem;

			opacity: 0.75;

			margin-bottom: 3rem;

			transition:
				opacity 0.3s ease,
				transform 0.3s ease;

		}

		/* ENVELOPE WRAPPER */

		.envelope-wrapper {

			position: relative;

			width: 360px;
			height: 270px;

			margin: auto;

			perspective: 1600px;

		}

		.envelope {

			position: relative;

			width: 100%;
			height: 100%;

			overflow: visible;

		}

		/* BACK */

		.envelope-back {

			position: absolute;

			inset: 0;

			background: var(--envelope);

			border-radius: 14px;

			box-shadow:
				0 15px 35px var(--shadow),
				inset 0 1px 0 rgba(255,255,255,0.4);

			z-index: 1;

			transition:
				opacity 1s ease;

		}

		.envelope-back::before,
		.envelope-back::after {

			content: "";

			position: absolute;

			bottom: 0;

			width: 50%;
			height: 100%;

			background:
				rgba(255,255,255,0.12);

		}

		.envelope-back::before {

			left: 0;

			clip-path:
				polygon(
					0 100%,
					100% 0,
					100% 100%
				);

		}

		.envelope-back::after {

			right: 0;

			clip-path:
				polygon(
					0 0,
					100% 100%,
					0 100%
				);

		}

		/* INVITE */

		.letter {

			position: absolute;

			left: 50%;
			bottom: -120px;

			transform:
				translateX(-50%)
				scale(0.96);

			width: 94%;
			height: 430px;

			opacity: 0;

			z-index: 2;

			border-radius: 12px;

			overflow: hidden;

			box-shadow:
				0 15px 35px rgba(0,0,0,0.2);

			cursor: pointer;

			pointer-events: none;

			transition:
				bottom 1.2s cubic-bezier(.22,1,.36,1),
				transform 1.2s ease,
				opacity 0.9s ease;

		}

		.invite-image {

			width: 100%;
			height: 100%;

			object-fit: contain;

			background: white;

			display: block;

			border-radius: 12px;

		}

		/* MASK */

		.envelope-mask {

			position: absolute;

			left: 0;
			bottom: 0;

			width: 100%;
			height: 72%;

			background: var(--envelope);

			z-index: 4;

			border-bottom-left-radius: 14px;
			border-bottom-right-radius: 14px;

			box-shadow:
				inset 0 12px 20px rgba(0,0,0,0.08);

			transition:
				opacity 1s ease;

		}

		/* FRONT TRIANGLE */

		.envelope-front {

			position: absolute;

			left: 0;
			bottom: 0;

			width: 100%;
			height: 68%;

			background: var(--envelope);

			clip-path:
				polygon(
					0 100%,
					50% 0,
					100% 100%
				);

			z-index: 5;

			transition:
				opacity 1s ease;

		}

		/* TOP FLAP */

		.flap {

			position: absolute;

			top: 0;
			left: 0;

			width: 100%;
			height: 52%;

			background: var(--envelope-dark);

			clip-path:
				polygon(
					0 0,
					50% 100%,
					100% 0
				);

			transform-origin: top;

			backface-visibility: hidden;

			z-index: 7;

			transition:
				transform 1s cubic-bezier(.77,0,.18,1),
				opacity 1s ease;

		}

		/* SEAL */

		.seal {

			position: absolute;

			top: 78px;
			left: 50%;

			transform: translateX(-50%);

			width: 60px;
			height: 60px;

			border-radius: 50%;

			background: var(--seal);

			display: flex;
			align-items: center;
			justify-content: center;

			color: white;

			font-weight: bold;

			box-shadow:
				0 6px 15px rgba(0,0,0,0.2);

			z-index: 10;

			cursor: pointer;

			transition:
				transform 0.5s ease,
				opacity 0.5s ease;

		}

		/* OPEN STATE */

		.envelope-wrapper.open .seal {

			transform:
				translateX(-50%)
				scale(1.5)
				rotate(25deg);

			opacity: 0;

		}

		.envelope-wrapper.open .flap {

			transform:
				rotateX(180deg)
				translateY(-35px);

			opacity: 0;

		}

		.envelope-wrapper.open .envelope-back,
		.envelope-wrapper.open .envelope-front,
		.envelope-wrapper.open .envelope-mask {

			opacity: 0;

		}

		.envelope-wrapper.open .letter {

			bottom: -20px;

			transform:
				translateX(-50%)
				scale(1);

			opacity: 1;

			z-index: 20;

			pointer-events: auto;

		}

		/* FOOTER */

		.footer {

			margin-top: 2.5rem;

			font-size: 0.95rem;

			opacity: 0.65;

			line-height: 1.7;

		}

		.footer span {

			font-size: 0.8rem;

			opacity: 0.7;

		}

		/* MOBILE */

		@media (max-width: 480px) {

			.envelope-wrapper {

				width: 310px;
				height: 240px;

			}

			.letter {

				width: 96%;
				height: 370px;

			}

		}

	</style>

</head>

<body>

	<main>

		<h1>
			Catherine & Luke
		</h1>

		<div
			class="subtitle"
			id="subtitle"
		>
			Click the seal to open
		</div>

		<div
			class="envelope-wrapper"
			id="envelope"
		>

			<div class="envelope">

				<div class="envelope-back"></div>

				<div
					class="letter"
					id="letter"
				>

					<img
						src="/Wedding Invite - 1.png"
						alt="Wedding Invitation"
						class="invite-image"
					/>

				</div>

				<div class="envelope-mask"></div>

				<div class="envelope-front"></div>

				<div class="flap"></div>

				<div
					class="seal"
					id="seal"
				>
					C&L
				</div>

			</div>

		</div>

		<div class="footer">

			We cannot wait to celebrate with you

			<br />

			<span>
				Made by Luke ©
			</span>

		</div>

	</main>

	<script>

		if (
			localStorage.getItem('wedding_access')
			!== 'true'
		) {

			window.location.href = '/';

		}

		const seal =
			document.getElementById('seal');

		const envelope =
			document.getElementById('envelope');

		const subtitle =
			document.getElementById('subtitle');

		const letter =
			document.getElementById('letter');

		let opened = false;

		seal.addEventListener('click', () => {

			if (opened) return;

			opened = true;

			envelope.classList.add('open');

			setTimeout(() => {

				subtitle.textContent =
					"Click the invite";

			}, 800);

		});

		letter.addEventListener('click', () => {

			if (!opened) return;

			window.open(
				'/invitation.pdf#view=FitH',
				'_blank'
			);

		});

	</script>

</body>
</html>
