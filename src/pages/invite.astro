<script>
	if (localStorage.getItem('wedding_access') !== 'true') {
		window.location.href = '/';
	}
</script>
---
import BaseHead from '../components/BaseHead.astro';

const SITE_TITLE = "Luke & Catherine";
const SITE_DESCRIPTION = "Wedding Invitation";
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

	<style>
		:root {
			--bg1: #faf7f2;
			--bg2: #f2e8de;
			--paper: #fffdfb;
			--envelope: #e8d7c8;
			--flap: #dcc5b2;
			--seal: #a44c58;
			--text: #4e4039;
			--shadow: rgba(0,0,0,0.15);
		}

		* {
			box-sizing: border-box;
		}

		body {
			margin: 0;
			height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			background: linear-gradient(to bottom, var(--bg1), var(--bg2));
			font-family: Georgia, serif;
			overflow: hidden;
			color: var(--text);
		}

		main {
			text-align: center;
		}

		h1 {
			font-size: 3rem;
			font-weight: 400;
			letter-spacing: 2px;
			margin-bottom: 1rem;
		}

		.subtitle {
			font-size: 1.2rem;
			margin-bottom: 3rem;
			opacity: 0.8;
		}

		.envelope-wrapper {
			position: relative;
			width: 340px;
			height: 240px;
			margin: auto;
			cursor: pointer;
			perspective: 1200px;
		}

		.envelope {
			position: absolute;
			width: 100%;
			height: 100%;
			background: var(--envelope);
			border-radius: 10px;
			box-shadow: 0 15px 35px var(--shadow);
			overflow: hidden;
		}

		/* BACK TRIANGLES */
		.envelope::before,
		.envelope::after {
			content: "";
			position: absolute;
			bottom: 0;
			width: 50%;
			height: 100%;
			background: rgba(255,255,255,0.15);
		}

		.envelope::before {
			left: 0;
			clip-path: polygon(0 100%, 100% 0, 100% 100%);
		}

		.envelope::after {
			right: 0;
			clip-path: polygon(0 0, 100% 100%, 0 100%);
		}

		.flap {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 52%;
			background: var(--flap);
			clip-path: polygon(0 0, 50% 100%, 100% 0);
			transform-origin: top;
			transition: transform 1s ease;
			z-index: 5;
			box-shadow: 0 4px 8px rgba(0,0,0,0.08);
		}

		.letter {
			position: absolute;
			left: 50%;
			bottom: 0;
			transform: translateX(-50%);
			width: 88%;
			height: 190px;
			background: var(--paper);
			border-radius: 6px;
			box-shadow: 0 5px 15px rgba(0,0,0,0.08);
			transition: transform 1.2s ease;
			z-index: 2;
		}

		.letter::before {
			content: "Luke & Catherine";
			position: absolute;
			top: 40px;
			left: 50%;
			transform: translateX(-50%);
			font-size: 1.4rem;
			letter-spacing: 1px;
			color: var(--text);
		}

		.letter::after {
			content: "Request the pleasure of your company";
			position: absolute;
			top: 90px;
			left: 50%;
			transform: translateX(-50%);
			font-size: 0.9rem;
			opacity: 0.7;
			width: 80%;
		}

		.seal {
			position: absolute;
			top: 78px;
			left: 50%;
			transform: translateX(-50%);
			width: 58px;
			height: 58px;
			border-radius: 50%;
			background: var(--seal);
			z-index: 10;
			display: flex;
			align-items: center;
			justify-content: center;
			color: white;
			font-size: 1rem;
			font-weight: bold;
			box-shadow: 0 6px 15px rgba(0,0,0,0.2);
			transition:
				transform 0.5s ease,
				opacity 0.5s ease;
		}

		.footer {
			margin-top: 2.5rem;
			font-size: 0.95rem;
			opacity: 0.65;
		}

		/* OPEN STATES */

		.envelope-wrapper.open .seal {
			transform: translateX(-50%) scale(1.5) rotate(25deg);
			opacity: 0;
		}

		.envelope-wrapper.open .flap {
			transform: rotateX(180deg);
		}

		.envelope-wrapper.open .letter {
			transform: translateX(-50%) translateY(-90px);
		}

		@media (max-width: 600px) {
			h1 {
				font-size: 2.2rem;
			}

			.envelope-wrapper {
				width: 280px;
				height: 200px;
			}

			.letter {
				height: 160px;
			}
		}
	</style>
</head>

<body>

	<main>
		<h1>Luke & Catherine</h1>

		<div class="subtitle">
			Click the seal to open
		</div>

		<div class="envelope-wrapper" id="envelope">

			<div class="envelope">

				<div class="letter"></div>

				<div class="flap"></div>

				<div class="seal" id="seal">
					L&C
				</div>

			</div>
		</div>

		<div class="footer">
			We cannot wait to celebrate with you
		</div>
	</main>

	<script>
		const seal = document.getElementById('seal');
		const envelope = document.getElementById('envelope');

		seal.addEventListener('click', () => {

			envelope.classList.add('open');

			setTimeout(() => {
				window.open('/invitation.pdf', '_blank');
			}, 1800);

		});
	</script>

</body>
</html>
