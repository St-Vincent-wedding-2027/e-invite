---
const SITE_TITLE = "Catherine & Luke";
const SITE_DESCRIPTION = "Wedding Invitation";
---

<!doctype html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<title>{SITE_TITLE}</title>

	<meta name="description" content={SITE_DESCRIPTION} />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />

	<style>
		:root {
			--bg1: #faf7f2;
			--bg2: #f2e8de;
			--envelope: #e7d6c6;
			--envelope-dark: #dcc5b2;
			--seal: #a44c58;
			--text: #4e4039;
			--shadow: rgba(0,0,0,0.15);
		}

		* { box-sizing: border-box; }

		body {
			margin: 0;
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			font-family: Georgia, serif;
			background: linear-gradient(to bottom, var(--bg1), var(--bg2));
			color: var(--text);
		}

		main {
			text-align: center;
			padding: 2rem;
		}

		h1 {
			font-size: clamp(2.4rem, 5vw, 3.6rem);
			font-weight: 400;
			letter-spacing: 2px;
			margin-bottom: 1rem;
		}

		.subtitle {
			font-size: 1.1rem;
			opacity: 0.75;
			margin-bottom: 2rem;
		}

		/* CENTER BLOCK (IMPORTANT FIX) */
		.center-stage {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 20px;
		}

		/* ENVELOPE */
		.envelope-wrapper {
			position: relative;
			width: 360px;
			height: 270px;
			perspective: 1400px;
			z-index: 2;
		}

		.envelope {
			position: relative;
			width: 100%;
			height: 100%;
		}

		.envelope-back {
			position: absolute;
			inset: 0;
			background: var(--envelope);
			border-radius: 14px;
			box-shadow: 0 15px 35px var(--shadow);
			z-index: 1;
			transition: opacity 1s ease;
		}

		.envelope-front {
			position: absolute;
			left: 0;
			bottom: 0;
			width: 100%;
			height: 68%;
			background: var(--envelope);
			clip-path: polygon(0 100%, 50% 0, 100% 100%);
			z-index: 4;
			transition: opacity 1s ease;
		}

		.flap {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 52%;
			background: var(--envelope-dark);
			clip-path: polygon(0 0, 50% 100%, 100% 0);
			transform-origin: top;
			z-index: 6;
			transition: transform 1s cubic-bezier(.77,0,.18,1), opacity 1s ease;
		}

		.seal {
			position: absolute;
			top: 78px;
			left: 50%;
			transform: translateX(-50%);
			width: 60px;
			height: 60px;
			border-radius: 50%;
			background: var(--seal);
			display: flex;
			align-items: center;
			justify-content: center;
			color: white;
			font-weight: bold;
			z-index: 10;
			cursor: pointer;
			transition: transform 0.5s ease, opacity 0.5s ease;
		}

		/* REVEAL AREA (THIS IS THE MAGIC FIX) */
		.reveal-zone {
			width: 100%;
			max-width: 340px;
			height: 0;
			opacity: 0;
			transform: translateY(20px);
			overflow: hidden;
			transition: all 1.2s cubic-bezier(.22,1,.36,1);
		}

		.reveal-zone img {
			width: 100%;
			height: auto;
			display: block;
			border-radius: 12px;
			box-shadow: 0 15px 35px rgba(0,0,0,0.25);
			background: white;
		}

		/* OPEN STATE EXPANDS SPACE */
		.center-stage.open .reveal-zone {
			height: 520px; /* controls space expansion */
			opacity: 1;
			transform: translateY(0);
		}

		.envelope-wrapper.open .seal {
			opacity: 0;
			transform: translateX(-50%) scale(1.5) rotate(25deg);
		}

		.envelope-wrapper.open .flap {
			transform: rotateX(180deg) translateY(-30px);
			opacity: 0;
		}

		.envelope-wrapper.open .envelope-back,
		.envelope-wrapper.open .envelope-front {
			opacity: 0;
		}

		/* FOOTER */
		.footer {
			margin-top: 2.5rem;
			font-size: 0.95rem;
			opacity: 0.65;
			line-height: 1.7;
		}

		.click-hint {
			margin-top: 0.6rem;
			font-size: 0.85rem;
			opacity: 0;
			transform: translateY(8px);
			transition: all 0.6s ease;
		}

		.center-stage.open + .footer .click-hint {
			opacity: 0.7;
			transform: translateY(0);
		}

		@media (max-width: 480px) {
			.envelope-wrapper {
				width: 310px;
				height: 240px;
			}

			.center-stage.open .reveal-zone {
				height: 440px;
			}
		}
	</style>
</head>

<body>

<main>

	<h1>Catherine & Luke</h1>

	<div class="subtitle">Click the seal to open</div>

	<div class="center-stage" id="stage">

		<div class="envelope-wrapper" id="envelope">

			<div class="envelope">
				<div class="envelope-back"></div>
				<div class="envelope-front"></div>
				<div class="flap"></div>
				<div class="seal" id="seal">C&L</div>
			</div>

		</div>

		<div class="reveal-zone" id="reveal">
			<img src="/Wedding Invite - 1.png" />
		</div>

	</div>

	<div class="footer">
		We cannot wait to celebrate with you<br />
		Made by Luke ©

		<div class="click-hint" id="clickHint">
			Click image to open your invitation
		</div>
	</div>

</main>

<script>
	const seal = document.getElementById('seal');
	const stage = document.getElementById('stage');
	const envelope = document.getElementById('envelope');
	const clickHint = document.getElementById('clickHint');

	let opened = false;

	seal.addEventListener('click', () => {
		if (opened) return;

		opened = true;
		envelope.classList.add('open');
		stage.classList.add('open');

		setTimeout(() => {
			clickHint.classList.add('show');
		}, 900);
	});
</script>

</body>
</html>
